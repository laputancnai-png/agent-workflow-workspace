# Database
DATABASE_URL=postgres://aww:aww@localhost:5432/aww

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-32-chars-minimum-random-hex
REFRESH_SECRET=change-me-32-chars-minimum-random-hex-2

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend public URL (used to build GitHub OAuth callback URL)
BACKEND_URL=http://localhost:3000

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/v1/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare R2 (optional — artifacts >64KB are stored inline if not configured)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
