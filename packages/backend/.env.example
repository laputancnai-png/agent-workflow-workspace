# Database
DATABASE_URL=postgres://aww:aww@localhost:5432/aww

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-32-chars-minimum-random-hex
REFRESH_SECRET=change-me-32-chars-minimum-random-hex-2

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend public URL (used to build GitHub OAuth callback URL)
BACKEND_URL=http://localhost:3000

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/v1/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare R2 (optional — artifacts >64KB are stored inline if not configured)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# ── Embedded Agent Worker ─────────────────────────────────────────────────────
# The backend runs agent tasks in-process by default (no separate runner process).
# Set WORKER_ENABLED=false to disable the embedded worker entirely.
WORKER_ENABLED=true

# Unique machine ID for this instance's embedded runner (visible in the UI)
WORKER_MACHINE_ID=embedded

# How often (ms) the worker polls for new tasks
WORKER_POLL_INTERVAL_MS=2000

# How often (ms) the worker sends a heartbeat for running tasks
WORKER_HEARTBEAT_INTERVAL_MS=30000

# Max wall-clock time (ms) an agent subprocess may run before being killed
WORKER_AGENT_TIMEOUT_MS=600000

# Token budget passed to the agent (limits LLM spend per task)
WORKER_MAX_TOKENS_BUDGET=200000

# Directory where git repos are cloned for agent tasks
WORKER_REPO_CACHE_DIR=.aww-repos

# Override path to the agent dispatcher script (auto-detected if unset)
# AGENT_DISPATCHER_PATH=

# ── LLM Providers (at least one required for agent tasks) ────────────────────
# OpenClaw Gateway (recommended for self-hosted)
OPENCLAW_GATEWAY_URL=
OPENCLAW_API_KEY=
OPENCLAW_AGENT_ID=main

# Anthropic direct API
ANTHROPIC_API_KEY=

# OpenAI direct API
OPENAI_API_KEY=

# Hermes (custom local LLM gateway)
HERMES_BASE_URL=
HERMES_API_KEY=

# ── Remote Runners (disabled by default in embedded mode) ────────────────────
# Set to true to allow external runner processes to register via the API.
# Requires REDIS_URL to be configured for task queuing.
REMOTE_RUNNERS_ENABLED=false
