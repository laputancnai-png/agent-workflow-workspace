{
  "name": "@aww/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aww": "./dist/cli.js"
  },
  "exports": {
    "./executor": {
      "types": "./src/executor.ts",
      "import": "./src/executor.ts",
      "default": "./src/executor.ts"
    },
    "./redact": {
      "types": "./src/redact.ts",
      "import": "./src/redact.ts",
      "default": "./src/redact.ts"
    },
    "./agents/protocol": {
      "types": "./src/agents/protocol.ts",
      "import": "./src/agents/protocol.ts",
      "default": "./src/agents/protocol.ts"
    },
    "./repo-manager": {
      "types": "./src/repo-manager.ts",
      "import": "./src/repo-manager.ts",
      "default": "./src/repo-manager.ts"
    },
    "./git-worker": {
      "types": "./src/git-worker.ts",
      "import": "./src/git-worker.ts",
      "default": "./src/git-worker.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "commander": "^12.0.0",
    "openai": "^4.47.0",
    "simple-git": "^3.24.0",
    "smol-toml": "^1.1.4",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "nock": "^13.5.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
